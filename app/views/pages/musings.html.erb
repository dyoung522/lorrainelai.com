<% content_for :title, "Musings - Lorraine Lai" %>

<div class="min-h-screen flex flex-col justify-center px-4 py-12 sm:py-16">
  <div class="max-w-2xl mx-auto w-full">
    <header class="text-center mb-12">
      <h1 class="text-3xl sm:text-4xl font-light tracking-wide text-text-primary mb-3">Musings</h1>
      <p class="text-text-secondary font-light">Thoughts, reflections, and stories</p>
    </header>

    <% if @posts.any? %>
      <div class="space-y-8">
        <% @posts.each do |post| %>
          <%= link_to post.substack_url, target: "_blank", rel: "noopener noreferrer", class: "block group" do %>
            <article class="bg-white dark:bg-gray-800 rounded-2xl shadow-md hover:shadow-lg border border-border-light transition-shadow p-6 sm:p-8">
              <% if post.cover_image_url.present? %>
                <div class="h-36 sm:h-44 overflow-hidden rounded-xl mb-6">
                  <img src="<%= post.cover_image_url %>"
                       alt="<%= post.title %>"
                       class="w-full h-full object-cover"
                       loading="lazy">
                </div>
              <% end %>

              <h2 class="text-lg sm:text-xl font-medium text-text-primary group-hover:text-dusty-rose-dark transition-colors mb-1">
                <%= post.title %>
              </h2>

              <% if post.description.present? %>
                <p class="text-sm text-text-secondary font-light italic mb-2"><%= post.description %></p>
              <% end %>

              <% if post.excerpt.present? %>
                <p class="text-sm text-text-secondary leading-relaxed mb-4"><%= truncate(post.excerpt, length: 200) %></p>
              <% end %>

              <div class="flex items-center justify-between text-xs text-text-muted pt-4 border-t border-border-light">
                <div class="flex items-center gap-2">
                  <% if post.published_at.present? %>
                    <time datetime="<%= post.published_at.iso8601 %>">
                      <%= post.published_at.strftime("%B %-d, %Y") %>
                    </time>
                  <% end %>

                  <% if post.reading_time_minutes.present? %>
                    <span>|</span>
                    <span><%= post.reading_time_minutes %> min read</span>
                  <% end %>

                  <% if post.paywall? %>
                    <span>|</span>
                    <span class="text-dusty-rose-dark">Subscribers only</span>
                  <% end %>
                </div>

                <span class="text-dusty-rose-dark group-hover:text-text-primary transition-colors font-medium">Read on Substack &rarr;</span>
              </div>
            </article>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16">
        <p class="text-text-muted text-lg">No musings yet. Check back soon!</p>
      </div>
    <% end %>
  </div>
</div>
